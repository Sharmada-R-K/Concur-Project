# ── Local AI — NO API KEYS NEEDED ─────────────────────────────────────────────
# Ollama local LLM server (default port, leave as-is)
OLLAMA_HOST=http://localhost:11434

# Model to use — llama3.2:3b is fast on Apple Silicon, < 2GB RAM
# Pull it once with: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# ── Layer 3 SAP Concur Stub ────────────────────────────────────────────────────
# Update when Layer 3 team confirms their server address and port
LAYER3_BASE_URL=http://localhost:8001

# Set to "true" to skip Layer 3 submission (test OCR + extraction + matching only)
DRY_RUN=false

# ── Service config ─────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
